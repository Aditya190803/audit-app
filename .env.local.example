# Copy to .env.local (gitignored via *.local) and adjust if needed.
# Loaded automatically by: scripts/local-release.js, bun run release:win:local

GITHUB_REPOSITORY=aditya190803/audit-app

# Used by release:check / electron-builder publish metadata (tag must match package.json version)
# UPDATE_FEED_URL=https://github.com/aditya190803/audit-app/releases/download/v1.1.5

LICENSE_CHECK_URL=https://the-ska-auditing-app.vercel.app/api/license
ALLOW_UNSIGNED_RELEASE=1
RELEASE_PLATFORM=windows

# Optional: only if you use electron-builder --publish (local builds use --publish never)
# GH_TOKEN=